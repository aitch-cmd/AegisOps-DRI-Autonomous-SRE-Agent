# ── Database ───────────────────────────────────────────────────────────────
# Connection string to the PostgreSQL database with the pgvector extension.
# Example using asyncpg driver:
DATABASE_URL="postgresql+asyncpg://postgres:admin123@localhost:5432/aegisops"

# ── Kubernetes ─────────────────────────────────────────────────────────────
# If you are running locally (e.g., Minikube, Docker Desktop), the kubernetes_asyncio
# client will automatically try to load your `~/.kube/config`.
# If you are deploying this app INSIDE a cluster as a pod, you do not need to set anything,
# the tools will detect the internal service account.
#
# If you need to force a specific kubeconfig path:
# KUBECONFIG="~/.kube/custom-config"

# ── Notifications ──────────────────────────────────────────────────────────
# Slack Incoming Webhook URL to send resolution summaries to a channel (e.g. #incidents)
# Create one at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX"

# ── Observability ──────────────────────────────────────────────────────────
# If your tools (like check_service_health) connect to a Prometheus instance:
# PROMETHEUS_URL="http://prometheus-operated.monitoring.svc.cluster.local:9090"
